# =============================================================================
# Finmate — Supabase environment variable template (supabase/.env.example)
# -----------------------------------------------------------------------------
# Copy to `.env` (gitignored) for local development, or set these in the
# Supabase dashboard (Project Settings -> Edge Functions -> Secrets) and via
# `supabase secrets set KEY=value` for deployed functions.
#
# SECURITY (docs/07-security-and-privacy.md):
#   - ONLY the public anon key ships in the iOS client bundle.
#   - The service-role key and ALL market-data provider keys live EXCLUSIVELY in
#     Edge Function environment variables, NEVER in the app, NEVER committed.
#   - Gitleaks scans CI for leaked secrets; keep real values out of git.
# =============================================================================

# --- Client-safe (ships in the iOS app) -------------------------------------
# The project URL and the PUBLIC anon key. RLS gates everything this key can do.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# --- SERVER-ONLY: Edge Function environment (never in the client) -----------
# Privileged key that BYPASSES RLS. Used only by the `delete-account` function
# to call auth.admin.deleteUser(verifiedUid). Server-side only.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Market-data provider API key(s), read by the `market-data` Edge Function.
# Holds the rate-provider credential server-side so no key ships in the app.
COINGECKO_API_KEY=YOUR_COINGECKO_API_KEY
# Optional FX provider (EUR/USD). Server-side only.
FX_PROVIDER_API_KEY=YOUR_FX_PROVIDER_API_KEY

# --- Auth: Sign in with Apple (config.toml references these) ----------------
# The Apple Service ID (client id) and the generated client-secret JWT.
# Server-side / CLI config only.
SUPABASE_AUTH_APPLE_CLIENT_ID=com.yourcompany.finmate.signin
SUPABASE_AUTH_APPLE_SECRET=YOUR_APPLE_CLIENT_SECRET_JWT
