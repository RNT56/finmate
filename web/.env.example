# Finmate web client environment.
# Only the PUBLIC anon key ships in any client. Never commit real keys —
# the service-role key and provider secrets live server-side (Edge Functions) only.
# The app builds and previews with sample data without these set.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
