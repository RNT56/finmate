{
  "name": "finmate-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Finmate web client — Vite + React 19 + TypeScript on the Supabase backend, Liquid Glass design language.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
